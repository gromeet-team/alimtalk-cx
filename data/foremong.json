{
  "dec_0": "adopt",
  "ce_0": "\n              #{고객명}님, 주문 감사합니다! 🌿<br>\n              <br>\n              주문이 정상적으로 접수됐어요.<br>\n              <br>\n              📦 주문 정보<br>\n              ▪️주문일 : #{주문일}<br>\n              ▪️상품명 : #{상품명}<br>\n              ▪️결제금액 : #{총결제금액}원<br>\n              <br>\n              꼼꼼하게 검수해서 안전하게 보내드릴게요.<br>\n              궁금한 점 있으시면 편하게 연락 주세요 😊<br>\n              <br>\n              🕐 평일 10:00~17:00<br>\n              (점심 12:30~13:30 / 주말·공휴일 휴무)\n              \n              <div class=\"btn-group\">\n                <div class=\"btn primary\">주문내역 확인하기</div>\n                <div class=\"btn\">포레몽 스토리 보기</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            ",
  "ce_1": "\n              #{고객명}님,&nbsp;<span style=\"background-color: rgb(248, 248, 248); font-family: Monaco, Menlo, Consolas, &quot;Courier New&quot;, monospace; font-size: 12px;\">지금 출발했어요! 🚚💨</span><br>주문하신 상품이 지금 이 순간<div>#{고객명}님을 향해 달려갑니다.</div><div><br>\n              <b>검수 완료 → 안전 포장 → 출고</b><br><br>\n              📦 배송 정보<br>\n              ▪️상품명 : #{상품명}<br>\n              ▪️송장번호 : #{송장번호}<br><br>\n              <span class=\"good\">💚 안심하세요!<br>\n              전자파 인증 · 라돈 검사 · 진드기 0%<br>\n              모든 안전 검증을 통과한 제품입니다.</span><br><br><div><div class=\"btn-group\">\n                <div class=\"btn primary\">배송조회 바로가기</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            </div></div>",
  "ce_2": "\n              #{고객명}님의 상품이<br>배송 완료되었습니다!<br><br>\n              📦 배송 완료 정보<br>\n              ▪️상품명 : #{상품명}<br>\n              ▪️송장번호 : #{송장번호}<br><br>\n              🧾 <b>정품등록 안내</b><br>\n              포레몽 공식 구매 고객님께<br>\n              정품 등록 서비스를 제공합니다.<br>\n              <span class=\"good\">아래 버튼으로 간편하게 등록해 주세요.</span>\n              <div class=\"btn-group\">\n                <div class=\"btn primary\">설치 전 주의사항 🎬</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            ",
  "ce_3": "\n              #{고객명}님, 안녕하세요!<br>\n              포레몽 온수매트<br>\n              <b>설치는 잘 되셨나요?</b><br><br>\n              혹시 설치 중 어려운 점이 있으셨다면<br>\n              아래 가이드 영상을 참고해 주세요.<br><br>\n              💧 매트 내부 물 관리를 하시면<br>\n              더 오래, 더 쾌적하게 사용할 수 있어요!<br>\n              <b>간단한 물빼기 방법을 확인해 보세요.</b><br><br>\n              불편한 점이 있다면<br>\n              언제든지 문의해 주세요.\n              <div class=\"btn-group\">\n                <div class=\"btn primary\">온수매트 물 빼는 방법</div>\n                <div class=\"btn\">고객센터 문의</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            ",
  "ce_4": "\n              #{고객명}님,<br>\n              포레몽 온수매트 잘 사용하고 계신가요? 🌿<br>\n              <br>\n              혹시 설치나 사용 중 불편한 점 있으시면<br>\n              편하게 말씀해 주세요.<br>\n              무상 A/S(기본 1년, 정품등록 시 총 2년), 끝까지 도와드릴게요.<br>\n              <br>\n              괜찮으셨다면 구매확정도 부탁드려요! 😉<br>\n              <br>\n              🕐 평일 10:00~17:00<br>\n              (점심 12:30~13:30 / 주말·공휴일 휴무)\n              \n              <div class=\"btn-group\">\n                <div class=\"btn primary\">구매확정 하기</div>\n                <div class=\"btn\">자주 묻는 질문</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            ",
  "ce_5": "\n              #{고객명}님,<br>\n              #{상품명} 사용하신 지<br>\n              일주일이 되었습니다.<br>\n              따뜻하게 잘 사용하고 계신가요?<br><br>\n              📸 <b>포토리뷰를 남겨주시면<br>\n              온수매트 전용 세탁망을<br>\n              감사의 마음으로 보내드립니다.</b><br><br>\n              고객님의 소중한 후기 한 줄이<br>\n              다음 고객의 선택에 큰 힘이 됩니다.<br>\n              진심으로 감사드립니다.\n              <div class=\"btn-group\">\n                <div class=\"btn primary\">📸 포토리뷰 남기기</div>\n                <div class=\"btn\">🎁 세탁망 신청하기</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            ",
  "ce_7": "<b>[ 포레몽 고객님만을 위한 혜택 🍀]</b><div><b>세탁할 때 필요한 세탁망,&nbsp;</b><b>미리 챙겨드릴게요&nbsp;</b></div><div><b><br></b></div><div>\n              포레몽 온수매트 사용하신 지<br>\n              어느덧 <b>한 달</b>이 되었습니다.<br><br>\n              <span class=\"good\">한 달 동안 따뜻하게 보내셨길 바랍니다.</span><br><br>\n              한 달 사용 후기를 남겨주시면<br>\n              공식몰에서 <b>감사 혜택</b>을 드립니다.\n              <div class=\"btn-group\">\n                <div class=\"btn primary\">한달 사용 후기 남기기</div>\n                <div class=\"btn\">사은품 신청</div>\n                <div class=\"btn\">포레몽 채널 추가</div>\n              </div>\n            </div>",
  "ce_8": "\n              #{고객명}님,<br><span style=\"background-color: rgb(255, 255, 255);\">주문 취소 요청이</span><span style=\"background-color: rgb(255, 255, 255);\">&nbsp;접수되었습니다.</span><br><br><span style=\"background-color: rgb(255, 255, 255);\">📦&nbsp;</span><b>주문 취소 정보</b><br><span style=\"background-color: rgb(255, 255, 255);\">▪️주문번호 : #{주문번호}</span><br><span style=\"background-color: rgb(255, 255, 255);\">▪️상품명 : #{상품명}</span><br><span style=\"background-color: rgb(255, 255, 255);\">▪️결제금액 : #{총결제금액}원</span><br><br><mark>🚨&nbsp;<b>도착보장(풀필먼트) 주문 안내</b></mark><br><span style=\"background-color: rgb(255, 255, 255);\">해당 주문은 실시간 출고 시스템으로</span><br><span style=\"background-color: rgb(255, 255, 255);\">요청 즉시 취소가 어려울 수 있습니다.</span><br><span style=\"background-color: rgb(255, 255, 255);\">출고가 이미 진행된 경우,</span><br><span style=\"background-color: rgb(255, 255, 255);\">상품 수령 후 반품으로 안내드릴 수 있는 점</span><br><span style=\"background-color: rgb(255, 255, 255);\">너그러히 양해 부탁드립니다.</span><br>\n              <br>\n              🕐 평일 10:00~17:00<br>\n              (점심 12:30~13:30 / 주말·공휴일 휴무)\n              \n                <div class=\"btn-group\">\n                  <div class=\"btn\">취소 진행상태 확인</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                </div>\n            ",
  "ce_9": "\n                #{고객명}님, 안녕하세요.<br>\n                포레몽입니다.<br><br>\n                취소가 정상적으로 완료되었습니다.<div><br>\n                💰 <b>환불 안내</b><br>\n                ▪️결제수단 : #{결제수단}<br>\n                ▪️환불 예상 : 약 3~7 영업일</div><div><br>\n                짧은 인연이었지만<br>\n                <span class=\"good\">다음 기회에 다시 찾아주시면<br>\n                감사의 마음을 드리겠습니다.</span><br><br>\n                더 나은 포레몽이 되도록<br>\n                소중한 의견을 남겨주세요.\n                <div class=\"btn-group\">\n                  <div class=\"btn\">의견 남기기</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                  <div class=\"btn\">포레몽 채널 추가</div>\n                </div>\n            </div>",
  "ce_10": "\n              #{고객명}님,<br>\n              교환 요청 접수했어요.<br>\n              <br>\n              📦 교환 진행 안내<br>\n              ▪️수거 → 입고 확인 → 교환 상품 발송<br>\n              ▪️예상 소요 : 영업일 기준 3~5일<br>\n              <br>\n              불편을 드려서 정말 죄송해요.<br>\n              진행 중 궁금한 점 있으시면 편하게 연락 주세요.<br>\n              <br>\n              🕐 평일 10:00~17:00<br>\n              (점심 12:30~13:30 / 주말·공휴일 휴무)\n              \n                <div class=\"btn-group\">\n                  <div class=\"btn\">교환 진행상태 확인</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                </div>\n            ",
  "ce_11": "\n              #{고객명}님,<br>\n              교환 상품이 발송됐습니다! 🌿<br>\n              <br>\n              📦 교환 배송 정보<br>\n              ▪️상품명 : #{상품명}<br>\n              ▪️송장번호 : #{송장번호}<br>\n              <br>\n              기다려주셔서 감사해요.<br>\n              이번엔 불편함 없이 따뜻하게 사용하시길 바랍니다 😊\n              \n                <div class=\"btn-group\">\n                  <div class=\"btn\">배송조회 바로가기</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                  <div class=\"btn\">포레몽 채널 추가</div>\n                </div>\n            ",
  "ce_12": "\n              #{고객명}님,<br>\n              반품 요청 접수했어요.<br>\n              <br>\n              📦 반품 진행 안내<br>\n              ▪️수거 → 입고 확인 → 환불 처리<br>\n              ▪️예상 소요 : 입고 확인 후 5~7영업일<br>\n              <br>\n              혹시 제품 불량이나 문제가 있으셨다면<br>\n              무상 A/S(기본 1년, 정품등록 시 총 2년)로도 빠르게 도와드릴 수도 있어요.<br>\n              반품 대신 A/S 원하시면 편하게 말씀해 주세요.<br>\n              <br>\n              🕐 평일 10:00~17:00<br>\n              (점심 12:30~13:30 / 주말·공휴일 휴무)\n              \n                <div class=\"btn-group\">\n                  <div class=\"btn\">반품 진행상태 확인</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                </div>\n            ",
  "ce_13": "\n              #{고객명}님,<br>\n              반품 처리 완료됐습니다.<br>\n              <br>\n              💰 반품 정보<br><div><span style=\"background-color: rgb(255, 255, 255);\">▪️주문번호 : #{주문번호}</span><br><span style=\"background-color: rgb(255, 255, 255);\">▪️상품명 : #{상품명}</span><br><span style=\"background-color: rgb(255, 255, 255);\">▪️환불금액 : #{총결제금액}</span><br><br><span style=\"background-color: rgb(255, 255, 255);\">회수된 상품이 상태 검수가 완료되어</span><br><span style=\"background-color: rgb(255, 255, 255);\">반품이 정상적으로 승인 되었습니다.</span><br>\n              <br>\n              불편하게 해드려서 죄송해요.<br>\n              어떤 점이 아쉬우셨는지 알려주시면<br>\n              꼭 참고할게요.\n              \n                <div class=\"btn-group\">\n                  <div class=\"btn\">의견 남기기</div>\n                  <div class=\"btn\">고객센터 문의</div>\n                  <div class=\"btn\">포레몽 채널 추가</div>\n                </div>\n            </div>",
  "ce_14": "\n              #{고객명}님, 포레몽 정품 등록이<br>\n              완료되었습니다! 🎉<br><br>\n              포레몽과 함께 해주셔서 감사해요.<br>\n              끝까지 책임지겠습니다.<br><br>\n              🛡 무상 A/S 1년 → 2년 보장<br>\n              #{보증만료일}까지 안심하고<br>\n              사용하세요.<br><br>\n              A/S 문의는 언제든지<br>\n              포레몽 채널로 연락해 주세요.\n              <div class=\"btn-group\">\n                <div class=\"btn\">채널추가</div>\n              </div>\n            ",
  "ce_15": "\n              #{고객명}님, 포레몽 온수매트<br>\n              A/S 보증이 30일 후 만료됩니다. 🛡<br><br>\n              📅 보증 만료일: #{보증만료일}<br><br>\n              만료 전 불편하신 점이 있으시면<br>\n              포레몽 카카오채널로 언제든 연락주세요.<br>\n              구매 후에도 끝까지 책임지겠습니다. 🔥\n              <div class=\"btn-group\">\n                <div class=\"btn\">채널추가</div>\n              </div>\n            ",
  "ce_6": "#{고객명}님, 안녕하세요😊<br><br><p class=\"isSelectedEnd\">현재 일부 고객님들을 대상으로<br>제품 사용 경험에 대한 의견을 듣고 있습니다.</p><p class=\"isSelectedEnd\"><br></p><p>고객님의 사용 경험이 큰 도움이 될 것 같아<br>조심스럽게 인터뷰 참여를 요청드립니다 🙏</p><div><br>✅ 약 10분 내외 간단 참여<br>✅ 참여 시 사은품 증정<br><br>아래 버튼을 통해<br>편하신 시간으로 예약 부탁드립니다.&nbsp;</div><div><br></div><div>⏰ 선착순으로 진행되고 있어<br>조기 마감될 수 있는 점 양해 부탁드립니다.</div><div><div class=\"btn-group\">\n                <div class=\"btn primary\">🎁참여하고 혜택 받기</div>\n                <div class=\"btn\">고객센터 문의</div>\n              </div>\n            </div>",
